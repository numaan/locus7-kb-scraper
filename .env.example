# Copy to .env and adjust. Nothing here is required to SCRAPE; these tune crawling + the optional push.

# Crawling
KB_USER_AGENT="locus7-kb-scraper/0.1 (+https://github.com/numaan/locus7)"
KB_TIMEOUT_S=30
KB_MAX_RETRIES=3
KB_RESPECT_ROBOTS=true        # set false ONLY for sites you own / have permission to crawl
KB_DATA_DIR=./data

# Optional push to Qdrant (requirements-push.txt)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=locus7_kb
KB_EMBED_MODEL=BAAI/bge-small-en-v1.5
